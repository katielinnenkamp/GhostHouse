  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "She slowly makes her way through the woods, the <i>celestial</i> light
    making it just bright enough to see the ground. The College of <i>Somber Arts</i>
    has sent her on a mission to recover an important artifact. Rumors say an old
    wizard who lives in the eastern mountains stole it many years ago. But to reach
    him, she must first travel through the most dangerous woods in the land. It is
    common knowledge that this forest is infested with bloodthirsty gnolls and <i>forest
    trolls</i>. No one passes through here unless absolutely necessary. She will
    need to use her talent for <i>spellcasting</i> to make it out alive. \n"
  m_isRightToLeft: 0
